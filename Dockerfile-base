# Gunakan image dasar Python (vLLM butuh Python >= 3.10).
# CUDA runtime disediakan oleh host RunPod (nvidia runtime); wheel vLLM
# membawa pustaka nvidia-*-cu12 yang dibutuhkan.
FROM python:3.10-slim

# Set work directory di dalam container
WORKDIR /app

# Salin semua file ke dalam container
COPY requirements.txt .

# Instal dependencies
RUN pip install --no-cache-dir -r requirements.txt
