# =============================================================================
# Salin file ini ke `.env` lalu isi nilainya:  cp .env.example .env
# =============================================================================

# --- Endpoint OpenAI-compatible (WAJIB diisi) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=http://157.180.30.121:20128/v1
MODEL=openrouter/deepseek/deepseek-v4-flash

# --- Tuning terjemahan ---
# Jumlah kalimat per request (lebih besar = lebih sedikit request).
CHUNK_SIZE=100
# Jumlah request paralel.
CONCURRENCY=8
TEMPERATURE=0.3
# Retry per request bila gagal.
MAX_RETRIES=2
# Batas token output per request (cukup besar agar balasan tidak terpotong).
MAX_TOKENS=8192

# --- Server ---
# Port HTTP yang diekspos di host.
PORT=8000
